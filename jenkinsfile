pipeline {
    agent any 
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build Docker Image') {
            steps {
                // This builds your container automatically
                sh 'docker build -t exam-system-image .'
            }
        }
        stage('Test Environment') {
            steps {
                echo 'Testing if the server starts...'
                // Basic check to see if the index file exists
                sh 'test -f index.html'
            }
        }
    }
    post {
        success {
            echo 'CI/CD Pipeline Completed Successfully!'
        }
    }
}